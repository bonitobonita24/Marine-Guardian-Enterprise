{
  "name": "marine-guardian-enterprise",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "tools:validate-inputs": "node tools/validate-inputs.mjs",
    "tools:check-env": "node tools/check-env.mjs",
    "tools:check-product-sync": "node tools/check-product-sync.mjs",
    "tools:hydration-lint": "node tools/hydration-lint.mjs",
    "db:migrate": "turbo run db:migrate --filter=@marine-guardian/db",
    "db:migrate:dev": "turbo run db:migrate:dev --filter=@marine-guardian/db",
    "db:seed": "turbo run db:seed --filter=@marine-guardian/db",
    "db:studio": "turbo run db:studio --filter=@marine-guardian/db",
    "db:generate": "turbo run db:generate --filter=@marine-guardian/db",
    "db:reset": "turbo run db:reset --filter=@marine-guardian/db"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
