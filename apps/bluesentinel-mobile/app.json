{
  "expo": {
    "name": "BlueSentinel",
    "slug": "bluesentinel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bluesentinel",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ph.gov.marinetech.bluesentinel"
    },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#0ea5e9" },
      "package": "ph.gov.marinetech.bluesentinel"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow BlueSentinel to use your location for patrol tracking." }],
      ["expo-camera", { "cameraPermission": "Allow BlueSentinel to access your camera to capture evidence photos." }],
      ["expo-notifications", { "icon": "./assets/notification-icon.png", "color": "#0ea5e9" }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
