FROM node:22-bookworm AS base
RUN npm install -g pnpm turbo

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/db/package.json ./packages/db/
COPY packages/ui/package.json ./packages/ui/
COPY packages/api-client/package.json ./packages/api-client/
COPY packages/jobs/package.json ./packages/jobs/
COPY packages/storage/package.json ./packages/storage/
COPY apps/marine-guardian-enterprise/package.json ./apps/marine-guardian-enterprise/
RUN pnpm install --frozen-lockfile

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN pnpm --filter @marine-guardian/db prisma generate
RUN pnpm turbo build --filter=marine-guardian-enterprise

FROM node:22-bookworm AS runner
WORKDIR /app
ENV NODE_ENV=production
# Copy Prisma engines (required for Prisma 6 query engine)
# Copy the entire .pnpm prisma structure
COPY --from=builder /app/node_modules/.pnpm /app/node_modules/.pnpm
# Copy standalone app
COPY --from=builder /app/apps/marine-guardian-enterprise/.next/standalone ./
COPY --from=builder /app/apps/marine-guardian-enterprise/.next/static ./apps/marine-guardian-enterprise/.next/static
COPY --from=builder /app/apps/marine-guardian-enterprise/public ./apps/marine-guardian-enterprise/public
EXPOSE 3000
CMD ["node", "apps/marine-guardian-enterprise/server.js"]
