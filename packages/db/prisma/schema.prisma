// Marine Guardian Enterprise — Prisma Schema
// Runtime role: mg_app (RLS enforced, NOT superuser)
// Migration role: mg_migrate (BYPASSRLS, never used at runtime)
// RLS policies: prisma/migrations/apply_rls_policies.sql

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TenantType {
  LGU
  BlueAlliance
}

enum Role {
  SUPER_ADMIN
  FISHERIES_OFFICER
  ENCODER
  VIEWER
  PATROLLER
  BA_ADMIN
  BA_ANALYST
  BA_RANGER
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  ENDANGERED
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityCategory {
  BOAT_OWNER_OPERATOR
  CAPTURE_FISHING
  GLEANING
  VENDOR
  FISH_PROCESSING
  AQUACULTURE
}

enum VesselType {
  MOTORIZED
  NON_MOTORIZED
}

enum PermitType {
  FISHING_VESSEL
  COMMERCIAL_FISHING
}

enum PermitStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum ProgramType {
  EQUIPMENT_DISTRIBUTION
  LIVELIHOOD_SUBSIDY
  TRAINING
}

enum IncidentStatus {
  REPORTED
  UNDER_INVESTIGATION
  RESOLVED
  DISMISSED
}

enum PatrolStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum MobilePlatform {
  ios
  android
}

// ─── MODELS ───────────────────────────────────────────────────────────────────
// RLS tables: Barangay, Fisherfolk, Vessel, Permit, CatchReport, Program,
//             ProgramBeneficiary, DistributionEvent, Incident, Patrol, AuditLog
// RLS exempt: Tenant, User, TenantMembership, Species, Notification, PushToken

model Tenant {
  id        String     @id @default(cuid())
  name      String
  type      TenantType
  slug      String     @unique
  logoUrl   String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  memberships      TenantMembership[]
  barangays        Barangay[]
  fisherfolks      Fisherfolk[]
  vessels          Vessel[]
  permits          Permit[]
  catchReports     CatchReport[]
  programs         Program[]
  incidents        Incident[]
  patrols          Patrol[]
  auditLogs        AuditLog[]
  lastActiveUsers  User[]             @relation("lastActiveTenant")

  @@map("tenants")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  passwordHash       String
  isActive           Boolean  @default(true)
  lastActiveTenantId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lastActiveTenant  Tenant?            @relation("lastActiveTenant", fields: [lastActiveTenantId], references: [id])
  memberships       TenantMembership[]
  notifications     Notification[]
  pushTokens        PushToken[]
  refreshTokens     RefreshToken[]
  incidentsReported Incident[]
  patrolsStarted    Patrol[]
  permitsApproved   Permit[]           @relation("permitApprovedBy")
  auditLogs         AuditLog[]

  @@map("users")
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Barangay {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fisherfolks Fisherfolk[] @relation("fisherfolkBarangay")
  vessels     Vessel[]     @relation("vesselHomePort")

  @@index([tenantId])
  @@map("barangays")
}

model Species {
  id         String   @id @default(cuid())
  name       String
  commonName String
  rarity     Rarity
  isGlobal   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  catchReports CatchReport[]

  @@map("species")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Fisherfolk {
  id                 String             @id @default(cuid())
  tenantId           String
  fisherfolkCode     String
  firstName          String
  middleName         String?
  lastName           String
  dateOfBirth        DateTime
  sex                Sex
  barangayId         String
  contactNumber      String?
  rsbsaNumber        String?
  activityCategories ActivityCategory[]
  photoUrl           String?
  signatureUrl       String?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barangay             Barangay             @relation("fisherfolkBarangay", fields: [barangayId], references: [id])
  vessels              Vessel[]
  catchReports         CatchReport[]
  programBeneficiaries ProgramBeneficiary[]
  distributionEvents   DistributionEvent[]

  @@unique([tenantId, fisherfolkCode])
  @@index([tenantId])
  @@index([barangayId])
  @@map("fisherfolks")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Vessel {
  id                 String     @id @default(cuid())
  tenantId           String
  ownerId            String
  vesselName         String
  registrationNumber String
  type               VesselType
  lengthMeters       Float?
  tonnage            Float?
  gearType           String?
  homePortBarangayId String
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner            Fisherfolk   @relation(fields: [ownerId], references: [id])
  homePortBarangay Barangay     @relation("vesselHomePort", fields: [homePortBarangayId], references: [id])
  permits          Permit[]
  catchReports     CatchReport[]
  incidents        Incident[]
  patrols          Patrol[]

  @@index([tenantId])
  @@index([ownerId])
  @@map("vessels")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Permit {
  id             String       @id @default(cuid())
  tenantId       String
  vesselId       String
  type           PermitType
  status         PermitStatus @default(DRAFT)
  issuedAt       DateTime?
  expiresAt      DateTime?
  approvedById   String?
  rejectionNotes String?
  documentUrl    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vessel     Vessel  @relation(fields: [vesselId], references: [id])
  approvedBy User?   @relation("permitApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([vesselId])
  @@index([status])
  @@map("permits")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model CatchReport {
  id              String   @id @default(cuid())
  tenantId        String
  vesselId        String
  fisherfolkId    String
  speciesId       String?
  speciesFreeText String?
  catchVolumeKg   Float
  catchDate       DateTime
  landingLocation String
  notes           String?
  createdAt       DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  fisherfolk Fisherfolk @relation(fields: [fisherfolkId], references: [id])
  species    Species?   @relation(fields: [speciesId], references: [id])

  @@index([tenantId])
  @@index([vesselId])
  @@index([catchDate])
  @@map("catch_reports")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Program {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  type        ProgramType
  description String?
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  beneficiaries ProgramBeneficiary[]
  distributions DistributionEvent[]

  @@index([tenantId])
  @@map("programs")
}

// RLS: inherits tenant scope via programId → Program.tenantId
model ProgramBeneficiary {
  id           String   @id @default(cuid())
  programId    String
  fisherfolkId String
  enrolledAt   DateTime @default(now())

  program    Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  fisherfolk Fisherfolk @relation(fields: [fisherfolkId], references: [id])

  @@unique([programId, fisherfolkId])
  @@index([programId])
  @@map("program_beneficiaries")
}

// RLS: inherits tenant scope via programId → Program.tenantId
model DistributionEvent {
  id               String   @id @default(cuid())
  programId        String
  fisherfolkId     String
  itemGiven        String
  quantity         Int
  distributionDate DateTime
  notes            String?
  createdAt        DateTime @default(now())

  program    Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  fisherfolk Fisherfolk @relation(fields: [fisherfolkId], references: [id])

  @@index([programId])
  @@map("distribution_events")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Incident {
  id           String         @id @default(cuid())
  tenantId     String
  reportedById String
  violatorName String
  violatorInfo String?
  vesselId     String?
  gearUsed     String?
  latitude     Float?
  longitude    Float?
  incidentDate DateTime
  description  String
  evidenceUrls String[]
  status       IncidentStatus @default(REPORTED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportedBy User    @relation(fields: [reportedById], references: [id])
  vessel     Vessel? @relation(fields: [vesselId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([incidentDate])
  @@map("incidents")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
model Patrol {
  id                 String       @id @default(cuid())
  tenantId           String
  vesselId           String
  startedById        String
  startTime          DateTime
  endTime            DateTime?
  fuelConsumedLiters Float?
  routeGeoJson       Json?
  notes              String?
  status             PatrolStatus @default(IN_PROGRESS)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vessel    Vessel @relation(fields: [vesselId], references: [id])
  startedBy User   @relation(fields: [startedById], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("patrols")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  channel   NotificationChannel
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// RLS: tenant_id = current_setting('app.current_tenant_id')
// IMMUTABLE — no delete or update by any role
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PushToken {
  id        String         @id @default(cuid())
  userId    String
  token     String         @unique
  platform  MobilePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model RefreshToken {
  id        String         @id @default(cuid())
  userId    String
  tokenHash String
  platform  MobilePlatform
  expiresAt DateTime
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
